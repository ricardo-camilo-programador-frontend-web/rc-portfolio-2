{
  "name": "ricardo-camilo---senior-frontend-portfolio",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/copy-sw.js",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "optimize:images": "node scripts/optimize-images.js",
    "lint": "biome check --write --unsafe . --max-diagnostics=4293000000",
    "lint:check": "biome check .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "validate": "tsc --noEmit && biome check src/ && vite build",
    "fix": "biome check --write --unsafe . && tsc --noEmit",
    "dead-deps": "knip",
    "dead-deps:fix": "knip --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "husky": "^9.1.7",
    "knip": "^6.21.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^8.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
